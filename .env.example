# Platform: android | ios (default: android)
PLATFORM=android

# Android
# Path to the APK built from clinic-mobile:
#   cd ../clinic-mobile && npx expo prebuild && cd android && ./gradlew assembleDebug
#   APK is at: android/app/build/outputs/apk/debug/app-debug.apk
ANDROID_APK_PATH=../clinic-mobile/android/app/build/outputs/apk/debug/app-debug.apk
ANDROID_APP_PACKAGE=com.clinicmobile
ANDROID_APP_ACTIVITY=.MainActivity

# iOS
IOS_APP_PATH=../clinic-mobile/ios/build/clinic-mobile.app
IOS_BUNDLE_ID=com.clinicmobile

# Set to true to skip reinstalling the app on every run (faster local iteration)
NO_RESET=false

# SUT backend
API_BASE_URL=http://10.0.2.2:3000/api/v1

# Claude Vision — required for @ai tests
ANTHROPIC_API_KEY=

# Test user credentials (must exist in SUT DB)
PATIENT_EMAIL=patient@example.com
PATIENT_PASSWORD=password123
DOCTOR_EMAIL=doctor@example.com
DOCTOR_PASSWORD=password123
