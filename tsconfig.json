{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["node", "@wdio/globals/types", "expect-webdriverio"],
    "skipLibCheck": true
  },
  "ts-node": {
    "transpileOnly": true
  },
  "include": [
    "wdio.conf.ts",
    "features/**/*.ts",
    "step-definitions/**/*.ts",
    "pages/**/*.ts",
    "support/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
